<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- 앱 타이틀 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reverb"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="40dp" />


        <!-- 권한 요청 버튼 (권한 없을 때만 표시) -->
        <Button
            android:id="@+id/btnGrantPermission"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="알림 접근 권한 부여하기"
            android:backgroundTint="#FF3B30"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- 상태 카드 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="서버 실행 중"
                    android:textSize="13sp"
                    android:textColor="#34C759"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="접속 주소"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvUrl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textSize="18sp"
                    android:textColor="#0A84FF"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvToken"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvConnections"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#888888" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 버튼들 -->
        <Button
            android:id="@+id/btnManageFilters"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="앱 필터 관리"
            android:backgroundTint="#2C2C2E"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnResetToken"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="토큰 재생성"
            android:backgroundTint="#2C2C2E"
            android:textColor="#AAAAAA"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
